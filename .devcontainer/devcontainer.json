{
	"name": "nestjs-prisma",
	"image": "node:22-bookworm",
	"features": {
		"ghcr.io/devcontainers-extra/features/prisma": {},
		"ghcr.io/devcontainers/features/common-utils": {
        "configureZshAsDefaultShell": true
    }
	},
	"runArgs": ["--name", "dev-container-seeyourchess-back"],

	"postCreateCommand": "npm i -g @nestjs/cli@11 && npm install",

	"customizations": {
		"vscode": {
			"extensions": [
			"dbaeumer.vscode-eslint",
			"esbenp.prettier-vscode",
			"prisma.prisma",
			"eamodio.gitlens"
			]
		}
	}
}