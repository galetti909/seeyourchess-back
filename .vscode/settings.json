{
  // Tabs e formatação
  "editor.tabSize": 2,
  "editor.insertSpaces": true,

   // Sempre formatar ao salvar
  "editor.formatOnSave": true,

  // Rodar ESLint ao salvar também
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },

  // Terminal integrado com ZSH por padrão
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "path": "/usr/bin/zsh"
    }
  },

  // Prettier como formatador padrão
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // TO DO Tree
  "todo-tree.general.tags": [
    "TODO",
    "WARN"
  ],
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "check",
      "background": "#33ff00",
      "foreground": "#000"
    },
    "WARN": {
      "icon": "check",
      "background": "#ffe600",
      "foreground": "#000"
    },
  },
  "todo-tree.filtering.includeGlobs": ["**/*.ts"],
  "todo-tree.filtering.excludeGlobs": [
    "**/node_modules/**",
    "**/dist/**"
  ],
  "todo-tree.tree.showScanModeButton": false,


  // Node/NestJS
  "typescript.tsdk": "node_modules/typescript/lib",

  // Auto save
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 3000,

  "json.schemas": [] //Active to stop warning on devcontainer.json, might have not intended effects
}